# Environment Variables Configuration

# API Configuration
# Replace with your actual API server URL
# Example: https://your-api-server.com/api
# Local development: http://localhost:5000/api
VITE_API_BASE_URL=http://localhost:5000/api

# Hospital API Key (must match HOSPITAL_API_KEY in IDP-Project/.env)
VITE_HOSPITAL_API_KEY=your_hospital_api_key_here

# Refresh Settings (in milliseconds)
VITE_REFRESH_INTERVAL=30000

# Error Handling
VITE_MAX_RETRY_ATTEMPTS=3

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_LOGS=false
